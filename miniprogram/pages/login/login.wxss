/* miniprogram/pages/login/login.wxss */
.login-container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.login-header {
  margin-top: 100rpx;
  margin-bottom: 80rpx;
  text-align: center;
}

.login-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 20rpx;
}

.login-subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.login-form {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-top: 20rpx;
}

.login-footer {
  margin-top: auto;
  padding: 40rpx 0;
  text-align: center;
}

.login-tip {
  font-size: 24rpx;
  color: #999;
}

/* 记住密码样式 */
.remember-row {
  display: flex;
  align-items: center;
  flex-direction: row;
  margin-bottom: 30rpx;
}

.remember-text {
  font-size: 28rpx;
  color: #666;
  margin-left: 16rpx;
}

/* 分割线样式 */
.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background-color: #e8e8e8;
}

.divider-text {
  font-size: 26rpx;
  color: #999;
  padding: 0 24rpx;
}

/* 微信登录按钮样式 */
.wechat-login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07c160;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}
