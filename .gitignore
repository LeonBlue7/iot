dist/
backend/dist/
build/
*.pyc
__pycache__/

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
docker-compose.override.yml
.nginx/

# SSL 证书（私人仓库，允许追踪）
# nginx/ssl/*.pem
# nginx/ssl/*.key

# 证书（允许忽略的）
certbot/
nginx/www/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store

# 临时文件
tmp/
temp/
.cache/

