# 物联网管理系统 - 项目根目录 .gitignore

# 环境变量
.env
.env.local
.env.*.local

# 依赖
node_modules/
backend/node_modules/
miniprogram/node_modules/

# 构建输出
dist/
backend/dist/
build/
*.pyc
__pycache__/

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
docker-compose.override.yml
.nginx/

# SSL 证书（敏感）
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/

# 证书（允许忽略的）
certbot/
nginx/www/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store

# 临时文件
tmp/
temp/
.cache/

# 测试覆盖率
coverage/
*.lcov
.nyc_output/

# Prisma
prisma/migrations/

# EMQX 数据
emqx_data/
emqx_log/

# 数据库卷数据（本地开发）
postgres_data/
redis_data/

# ODT 文档（二进制文件）
*.odt
*.tsbuildinfo
