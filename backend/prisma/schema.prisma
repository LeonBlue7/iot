generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 设备分组表
model DeviceGroup {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  devices Device[]

  @@index([name])
  @@map("device_groups")
}

// 设备表
model Device {
  id         String    @id @db.VarChar(20) // IMEI号
  productId  String?   @map("product_id") @db.VarChar(50)
  name       String?   @db.VarChar(100)
  simCard    String?   @map("sim_card") @db.VarChar(20)
  online     Boolean   @default(false)
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  groupId    Int?      @map("group_id")

  // Relations
  group       DeviceGroup?  @relation(fields: [groupId], references: [id])
  sensorData  SensorData[]
  params      DeviceParam?
  alarms      AlarmRecord[]
  controlLogs ControlLog[]

  @@index([groupId])
  @@map("devices")
}

// 传感器数据表
model SensorData {
  id             Int       @id @default(autoincrement())
  deviceId       String    @map("device_id") @db.VarChar(20)
  temperature    Decimal?  @db.Decimal(4, 1) // 温度
  humidity       Decimal?  @db.Decimal(4, 1) // 湿度
  current        Int? // 电流值
  signalStrength Decimal?  @map("signal_strength") @db.Decimal(4, 1) // 信号强度
  acState        Int?      @map("ac_state") // 空调状态
  acError        Int?      @map("ac_error") // 空调故障码
  tempAlarm      Int?      @map("temp_alarm") // 温度告警
  humiAlarm      Int?      @map("humi_alarm") // 湿度告警
  recordedAt     DateTime? @map("recorded_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  device Device @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([recordedAt])
  @@map("sensor_data")
}

// 设备参数表
model DeviceParam {
  id       Int    @id @default(autoincrement())
  deviceId String @unique @map("device_id") @db.VarChar(20)

  // 自动控制参数
  mode          Int      @default(0) // 0手动/1自动
  summerTempOn  Decimal? @map("summer_temp_on") @db.Decimal(4, 1)
  summerTempSet Decimal? @map("summer_temp_set") @db.Decimal(4, 1)
  summerTempOff Decimal? @map("summer_temp_off") @db.Decimal(4, 1)
  winterTempOn  Decimal? @map("winter_temp_on") @db.Decimal(4, 1)
  winterTempSet Decimal? @map("winter_temp_set") @db.Decimal(4, 1)
  winterTempOff Decimal? @map("winter_temp_off") @db.Decimal(4, 1)
  winterStart   Int?     @map("winter_start")
  winterEnd     Int?     @map("winter_end")
  acOffInterval Int?     @map("ac_off_interval")

  // 时间段参数
  workTime  String? @map("work_time") @db.VarChar(50)
  overtime1 String? @map("overtime_1") @db.VarChar(50)
  overtime2 String? @map("overtime_2") @db.VarChar(50)
  overtime3 String? @map("overtime_3") @db.VarChar(50)

  // 空调参数
  acCode      Int? @map("ac_code")
  acMode      Int? @map("ac_mode")
  acFanSpeed  Int? @map("ac_fan_speed")
  acDirection Int? @map("ac_direction")
  acLight     Int? @map("ac_light")
  minCurrent  Int? @map("min_current")

  // 告警参数
  alarmEnabled  Int? @map("alarm_enabled")
  tempHighLimit Int? @map("temp_high_limit")
  tempLowLimit  Int? @map("temp_low_limit")
  humiHighLimit Int? @map("humi_high_limit")
  humiLowLimit  Int? @map("humi_low_limit")

  // 其他
  uploadInterval Int?     @map("upload_interval")
  version        Int      @default(0)
  resetTimes     Int?     @map("reset_times")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  device Device @relation(fields: [deviceId], references: [id])

  @@map("device_params")
}

// 告警记录表
model AlarmRecord {
  id             Int       @id @default(autoincrement())
  deviceId       String    @map("device_id") @db.VarChar(20)
  alarmType      String    @map("alarm_type") @db.VarChar(20)
  alarmValue     Decimal?  @map("alarm_value") @db.Decimal(6, 1)
  threshold      Decimal?  @db.Decimal(6, 1)
  status         Int       @default(0) // 0未处理/1已确认/2已解决
  acknowledgedBy String?   @map("acknowledged_by") @db.VarChar(50)
  acknowledgedAt DateTime? @map("acknowledged_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  device Device @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([status])
  @@index([createdAt])
  @@map("alarm_records")
}

// 控制日志表
model ControlLog {
  id        Int      @id @default(autoincrement())
  deviceId  String   @map("device_id") @db.VarChar(20)
  action    String   @db.VarChar(20)
  value     Json? // 操作参数
  result    Int? // 结果码
  operator  String?  @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  device Device @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([createdAt])
  @@map("control_logs")
}

// ============== 管理后台模块 ==============

// 管理员用户表
model AdminUser {
  id                 Int       @id @default(autoincrement())
  username           String    @unique @map("username") @db.VarChar(50)
  email              String    @unique @map("email") @db.VarChar(100)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  name               String?   @db.VarChar(100)
  enabled            Boolean   @default(true)
  roleIds            Int[]     @default([]) @map("role_ids")
  mustChangePassword Boolean   @default(true) @map("must_change_password")
  lastLoginAt        DateTime? @map("last_login_at")
  lastLoginIp        String?   @map("last_login_ip") @db.VarChar(45)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  auditLogs AuditLog[]

  @@index([username])
  @@index([email])
  @@map("admin_users")
}

// 管理员角色表
model AdminRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique @map("name") @db.VarChar(50)
  description String?  @db.VarChar(200)
  permissions String[] @db.VarChar(50)
  isSystem    Boolean  @default(false) // 系统内置角色不可删除
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("admin_roles")
}

// 审计日志表
model AuditLog {
  id            Int      @id @default(autoincrement())
  adminUserId   Int      @map("admin_user_id") @db.Integer
  action        String   @map("action") @db.VarChar(50) // 操作类型
  resource      String   @map("resource") @db.VarChar(50) // 资源类型
  resourceId    String?  @map("resource_id") @db.VarChar(100) // 资源 ID
  resourceIdInt Int?     @map("resource_id_int") @db.Integer // 资源 ID (数字)
  details       Json?    @db.JsonB // 详细信息
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// 系统配置表
model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique @map("key") @db.VarChar(100)
  value       Json     @db.JsonB
  description String?  @db.VarChar(500)
  isPublic    Boolean  @default(false) // 是否公开配置
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("system_configs")
}
