# 服务器配置
NODE_ENV=development
PORT=3000
SERVER_URL=http://localhost:3000

# 数据库配置
# 生成密码：openssl rand -base64 32
DB_USER=iot_user
DB_PASSWORD=<请运行：openssl rand -base64 32>
DB_NAME=iot_db
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public"

# Redis 配置
# 生成密码：openssl rand -base64 32
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<请运行：openssl rand -base64 32>

# MQTT 配置
# 生产环境使用 mqtts:// 并配置 CA 证书
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=iot_server_
MQTT_CA_CERT_PATH=

# JWT 认证配置
# 生成密钥：openssl rand -base64 64
# ⚠️ 生产环境必须使用随机生成的 64 字符密钥！
JWT_SECRET=<请运行：openssl rand -base64 64>
JWT_EXPIRES_IN=24h

# 微信小程序配置
WECHAT_APPID=<你的小程序 AppID>
WECHAT_SECRET=<你的小程序 Secret>

# 初始化管理员密码
# ⚠️ 生产环境必须通过环境变量设置
# 生成随机密码：openssl rand -base64 16
INITIAL_ADMIN_PASSWORD=<请运行：openssl rand -base64 16>
