# ========================================
# 开发环境配置模板
# ========================================
#
# 使用方法：
# 1. 复制此文件为 .env
#    cp .env.example .env
# 2. 编辑 .env 填入本地配置
# 3. 使用 Docker 启动基础设施：
#    docker-compose up -d postgres redis emqx
#
# ⚠️ 注意：这是开发环境配置，不要与生产环境混淆
# 生产环境配置请参考 docs/DEPLOYMENT.md
# ========================================

# 服务器配置
NODE_ENV=development
PORT=3000
SERVER_URL=http://localhost:3000

# 数据库配置（本地开发）
# 使用 Docker: docker-compose up -d postgres
# 生成密码：openssl rand -base64 32
DB_USER=iot_user
DB_PASSWORD=<请运行：openssl rand -base64 32>
DB_NAME=iot_db
DATABASE_URL="postgresql://iot_user:your_password@localhost:5432/iot_db?schema=public"

# Redis 配置（本地开发）
# 使用 Docker: docker-compose up -d redis
# 开发环境密码可选
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT 配置（本地开发）
# 使用 Docker: docker-compose up -d emqx
# 开发环境连接本地 EMQX，无需认证
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=iot_server_dev_
MQTT_CA_CERT_PATH=

# JWT 认证配置
# 开发环境可不设置（自动生成随机密钥）
# 生成密钥：openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRES_IN=7d

# 微信小程序配置（开发环境可选）
WECHAT_APPID=
WECHAT_SECRET=

# 初始化管理员密码（开发环境）
# 可使用简单密码便于测试
INITIAL_ADMIN_PASSWORD=admin123

# ========================================
# 开发环境 vs 生产环境 对比
# ========================================
#
# | 配置项          | 开发环境              | 生产环境              |
# |----------------|----------------------|----------------------|
# | NODE_ENV       | development          | production           |
# | DATABASE_URL   | localhost:5432       | postgres:5432        |
# | REDIS_HOST     | localhost            | redis                |
# | MQTT_BROKER    | localhost:1883       | emqx:1883            |
# | MQTT_USERNAME  | (空)                 | test1                |
# | MQTT_PASSWORD  | (空)                 | test123              |
# | JWT_SECRET     | (自动生成)           | (预配置)             |
#
# 生产环境 MQTT 认凭据说明：
# - 用户名: test1
# - 密码: test123
# - 这些值已写入 4G模组嵌入式程序，无法更改
# ========================================