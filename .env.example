# 物联网管理系统 - 环境变量配置模板
#
# ========================================
# 使用 Docker 开发环境（推荐）
# ========================================
#
# 1. 复制此文件为 .env
#    cp .env.example .env
#
# 2. 开发环境使用默认值即可，无需修改
#
# 3. 启动完整开发环境：
#    docker-compose up -d
#
# 4. 运行数据库迁移（首次启动）：
#    docker-compose exec backend npx prisma migrate dev
#
# 5. 运行种子数据（创建测试用户和数据）：
#    docker-compose exec backend npm run prisma:seed
#
# 6. 查看服务日志：
#    docker-compose logs -f backend
#    docker-compose logs -f admin-web
#
# ⚠️ 注意：这是开发环境配置，不要与生产环境混淆
# 生产环境配置请参考 docker-compose.prod.yml 和 DEPLOYMENT.md
# ========================================

# ====================
# 数据库配置 (PostgreSQL)
# ====================
DB_USER=iot_user
DB_PASSWORD=<your_database_password>
DB_NAME=iot_db
DB_PORT=5432

# ====================
# Redis 配置
# ====================
REDIS_PASSWORD=<your_redis_password>
REDIS_PORT=6379

# ====================
# EMQX MQTT Broker 配置
# ====================
EMQX_USERNAME=admin
EMQX_PASSWORD=<your_emqx_dashboard_password>
# 开发环境 MQTT 无需认证（允许匿名）
MQTT_USERNAME=
MQTT_PASSWORD=

# ====================
# 后端服务配置
# ====================
NODE_ENV=development
PORT=3000

# ====================
# JWT 配置
# ====================
JWT_SECRET=<generate_random_secret_min_32_chars>
JWT_EXPIRES_IN=7d

# ====================
# 初始管理员密码
# ====================
INITIAL_ADMIN_PASSWORD=<your_admin_password>

# ====================
# 微信小程序配置（开发可选）
# ====================
WECHAT_APPID=
WECHAT_SECRET=

# ====================
# 开发环境访问地址
# ====================
# 后端 API:      http://localhost:3000
# 管理后台:      http://localhost:3001
# EMQX Dashboard: http://localhost:18083
# MQTT Broker:   localhost:1883
# PostgreSQL:    localhost:5432
# Redis:         localhost:6379
