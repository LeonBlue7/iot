# 物联网管理系统 - 环境变量配置

# ====================
# 数据库配置 (PostgreSQL)
# ====================
DB_USER=iot_user
DB_PASSWORD=请设置强密码
DB_NAME=iot_db
DB_PORT=5432
DB_HOST=localhost

# ====================
# Redis 配置
# ====================
REDIS_PASSWORD=请设置强密码
REDIS_PORT=6379
REDIS_HOST=localhost

# ====================
# EMQX MQTT Broker 配置
# ====================
EMQX_USERNAME=admin
EMQX_PASSWORD=请设置强密码
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# ====================
# 后端服务配置
# ====================
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# ====================
# JWT 配置（如果需要）
# ====================
JWT_SECRET=请生成随机密钥_至少 32 字符
JWT_EXPIRES_IN=7d

# ====================
# SSL 证书配置（生产环境）
# ====================
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# ====================
# 域名配置
# ====================
DOMAIN=www.jxbonner.cloud
